DOMAIN=sip.example.com
PUBLIC_IPV4=203.0.113.10
PRIVATE_IPV4=10.0.1.25
AWS_REGION=us-west-2
EC2_INSTANCE_ID=
DEBIAN_CODENAME=trixie
KAMAILIO_SERIES=6.1
KAMAILIO_APT_REPOSITORY=https://deb.kamailio.org/kamailio61
RTPENGINE_SERIES=13.5
RTPENGINE_RELEASE_REPOSITORY=https://github.com/sipwise/rtpengine/releases

ADMIN_CIDR=198.51.100.25/32
DEMO_CLIENT_CIDR=198.51.100.25/32

SIP_USER=websip
SIP_PASSWORD=change-me
SIP_PEER_USER=softphone
SIP_PEER_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me
DB_KAMAILIO_NAME=kamailio
DB_KAMAILIO_USER=kamailio
DB_KAMAILIO_PASSWORD=change-me

ICE_MODE=stun
STUN_URL=stun:stun.l.google.com:19302

ENABLE_TURN=false
TURN_USER=websip
TURN_PASSWORD=change-me
TURN_REALM=sip.example.com
TURN_PORT=3478
TURN_RELAY_PORT_MIN=31000
TURN_RELAY_PORT_MAX=31039

RTPENGINE_PORT_MIN=30000
RTPENGINE_PORT_MAX=30039
RTPENGINE_CONTROL_IP=127.0.0.1
RTPENGINE_CONTROL_PORT=22222

ENABLE_NGINX=true
WEB_CLIENT_ROOT=/var/www/webrtc-to-sip
TLS_CERT_PATH=/etc/letsencrypt/live/sip.example.com/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/sip.example.com/privkey.pem

KAMAILIO_WS_INTERNAL_PORT=8080
KAMAILIO_WSS_INTERNAL_PORT=4443
KAMAILIO_SIP_PORT=5060
